# Copy this file to .env.local (local dev) and set the same vars in your host
# (e.g. Vercel project settings) for production. Do NOT commit real keys.

# Supabase — project URL (base, no path) + anon (public) key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Polygon.io — stock quotes, search, price history (free tier works)
POLYGON_API_KEY=your_polygon_key

# Finnhub — company news (free tier works)
FINNHUB_API_KEY=your_finnhub_key

# Anthropic (Claude) — optional. Powers the AI trade debrief.
# Leave as-is to disable the debrief; the rest of the app works without it.
ANTHROPIC_API_KEY=your_anthropic_key

# Public base URL of the deployed app. Used for the server-side AI debrief
# callback. On Vercel this is auto-detected (VERCEL_URL); set it explicitly
# if you use a custom domain. Locally you can leave it unset.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
